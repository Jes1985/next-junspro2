{
  "name": "laravel/laravel",
  "type": "project",
  "description": "The Laravel Framework.",
  "keywords": [
    "framework",
    "laravel"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "academe/omnipay-authorizenetapi": " ~3.0",
    "anandsiddharth/laravel-paytm-wallet": "^2.0",
    "anhskohbo/no-captcha": "^3.3",
    "barryvdh/laravel-dompdf": "^3.0",
    "baselrabia/myfatoorah-with-laravel": "^1.0",
    "guzzlehttp/guzzle": "^7.0.1",
    "intervention/image": "^2.7",
    "ixudra/curl": "^6.22",
    "iyzico/iyzipay-php": "^2.0",
    "kreativdev/installer": "^1.0",
    "laravel-notification-channels/webpush": "^10.3",
    "laravel/framework": "^12.0",
    "laravel/socialite": "^5.5",
    "laravel/tinker": "^2.5",
    "maatwebsite/excel": "^3.1",
    "mews/purifier": "^3.3",
    "midtrans/midtrans-php": "^2.5",
    "mollie/laravel-mollie": "^3.1",
    "paypal/rest-api-sdk-php": "^1.14",
    "php-http/guzzle7-adapter": "^1.0",
    "phpmailer/phpmailer": "^6.4",
    "pusher/pusher-php-server": "^7.2",
    "razorpay/razorpay": "2.*",
    "spatie/laravel-cookie-consent": "^3.2",
    "bacon/bacon-qr-code": "^3.0",
    "laravel/nova": "^5.2",
    "stripe/stripe-php": "^14.0"
  },
  "require-dev": {
    "fakerphp/faker": "^1.9.1",
    "laravel/nova-devtool": "^1.8",
    "laravel/sail": "^1.27",
    "mockery/mockery": "^1.4.2",
    "nunomaduro/collision": "^8.1",
    "phpunit/phpunit": "^11.0",
    "spatie/laravel-ignition": "^2.3"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    },
    "files": [
      "app/Http/Helpers/Helper.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": [
        "kreativdev/installer"
      ]
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    },
    "platform": {
      "php": "8.3.0"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "repositories": {
    "nova": {
      "type": "composer",
      "url": "https://nova.laravel.com"
    },
    "paypal-sdk": {
      "type": "path",
      "url": "packages/paypal/rest-api-sdk-php"
    }
  }
}
